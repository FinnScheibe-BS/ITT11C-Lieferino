# Vorlage für die .env-Datei. Kopiere diese Datei zu ".env" und trage die
# echten Werte ein (die .env wird NICHT zu GitHub hochgeladen).

# Gmail-Konto, von dem die Mails verschickt werden:
GMAIL_USER=dein-konto@gmail.com

# Ein Gmail-APP-PASSWORT (16 Zeichen, NICHT das normale Passwort!):
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
